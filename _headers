# Security headers for every response (Cloudflare Pages reads this file).
# Deliberately conservative: no Content-Security-Policy yet, because the kit
# uses inline <script> and <style>, srcdoc iframes for the motion players,
# data: fonts, and blob: downloads, so a CSP needs testing before it ships.
# The four below add real protection with no risk of breaking the kit.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()

# Self-hosted fonts keep stable filenames, so cache them for a year.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
